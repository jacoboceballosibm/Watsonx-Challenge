# IBM Professional Marketplace — environment configuration
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Backend ───────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on (bound to localhost only)
PORT=8000
HOST=127.0.0.1

# ── watsonx.ai ────────────────────────────────────────────────────────────────
# Obtain from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_project_id_here

# ── Stale listing threshold ───────────────────────────────────────────────────
STALE_DAYS_THRESHOLD=30
