# IBM Professional Marketplace - environment configuration
# Copy this file to .env and fill in real values. Never commit .env to git.

# Backend
# Port the FastAPI server listens on (bound to localhost only)
PORT=8000
HOST=127.0.0.1

# Local database
DATABASE_URL=sqlite:///./prom.db

# Demo Authentication
# Password for all demo user accounts (for development/demo only)
DEMO_PASSWORD=demo123

# OpenAI
# The Agents SDK reads OPENAI_API_KEY from the environment.
OPENAI_API_KEY=your_openai_api_key_here

# Keep this on a mini model while prototyping. Override when needed.
OPENAI_CV_TAILOR_MODEL=gpt-4.1-mini

# Stale listing threshold
STALE_DAYS_THRESHOLD=30
